# Byte-compiled / optimized / DLL files
__pycache__/
*.pyc
*.pyo
*.pyd

# Environments
venv/
env/
.env
*.venv

# Model Artifacts (Auto-generated by pipeline)
models/*.pkl
models/*.joblib

